# Server .env.example – copy to .env and set values for local or production

PORT=21098
# If you get querySrv ETIMEOUT, try the standard (non-SRV) connection string from Atlas:
# Connect → Drivers → Node → toggle off "Connect using SRV", then copy the URI.
DB_CONNECTION=mongodb+srv://...
DB_NAME=Triphog

# App URLs (no trailing slash). Used for emails, redirects, upload URLs, CORS.
# Local:  FRONTEND_URL=http://localhost:5173  API_URL=http://localhost:21098
# Prod:   FRONTEND_URL=https://triphog.net     API_URL=https://api.triphog.net
FRONTEND_URL=https://triphog.net
API_URL=https://api.triphog.net

JWT_EXPIRES_IN=90d
JWT_SECRET=your-secret

NODE_ENV=production

# Gmail SMTP (for password reset, welcome emails, etc.)
# Use your full Gmail address and a Gmail App Password (not your normal password).
# Create one: https://support.google.com/accounts/answer/185833 (requires 2-Step Verification).
GMAIL_EMAIL=your@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

# OAuth – should match API_URL
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://api.triphog.net

# Optional
GOOGLE_MAPS_API_KEY=...
STRIPE_KEY=...
FIREBASE_NOTIFICATION_URL=...
